# ScytaleDroid Environment (example)

# ---- Database Credentials ----
SCYTALEDROID_DB_NAME=scytaledroid_database
SCYTALEDROID_DB_USER=scytale_user
SCYTALEDROID_DB_PASSWD=change-me-now
SCYTALEDROID_DB_HOST=localhost
SCYTALEDROID_DB_PORT=3306
SCYTALEDROID_DB_SCHEME=mysql
SCYTALEDROID_API_KEY=change-me
# Legacy publication/export path toggle (default off).
SCYTALEDROID_ENABLE_LEGACY_PUBLICATION=0

# ---- Global Runtime Mode ----
# Optional preset to seed sane defaults:
# - physical   => PROD / PHYSICAL / debug off / sys-test off
# - virtual    => DEV / VIRTUAL / debug on / sys-test off
# - validation => DEV / VIRTUAL / debug on / sys-test on
SCYTALEDROID_RUNTIME_PRESET=physical

# Keep these quiet for normal testers. The banner only surfaces runtime identity
# when DEBUG_MODE=True or EXECUTION_MODE=DEV.
SCYTALEDROID_DEBUG_MODE=False
SCYTALEDROID_EXECUTION_MODE=PROD
SCYTALEDROID_SYS_ENV=PHYSICAL
# Reserved for future automation / systems testing.
SCYTALEDROID_SYS_TEST=False

# Optional: direct URL override (normally built from the fields above)
# SCYTALEDROID_DB_URL=mysql://scytale_user:change-me-now@localhost:3306/scytaledroid_database

# Static progress cadence (milestones every N artifacts)
SCYTALEDROID_STATIC_PROGRESS_EVERY=5
