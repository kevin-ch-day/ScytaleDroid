# ScytaleDroid Environment (example)
#
# Copy to `.env` at repo root. Alternate path: set SCYTALEDROID_ENV_FILE (see `run_mariadb.sh`).
# Precedence: variables already set in the shell are NOT overwritten by `.env` (see db_config._load_dotenv).
#
# Password naming (canonical):
#   SCYTALEDROID_DB_PASSWD — primary MariaDB (matches Python db_config; **SCYTALEDROID_DB_PASS is legacy** — do not use for new setups).
#   SCYTALEDROID_PERMISSION_INTEL_DB_PASSWD — Permission Intel DB (**there is no …_PASS**).
# If SCYTALEDROID_PERMISSION_INTEL_DB_URL is set (non-empty), it overrides split HOST/USER/PASSWD/… for Intel.

# ---- Primary operational database (MariaDB/MySQL) ----
SCYTALEDROID_DB_HOST=localhost
SCYTALEDROID_DB_PORT=3306
SCYTALEDROID_DB_NAME=scytaledroid_core_prod
SCYTALEDROID_DB_USER=scytaledroid_operator
SCYTALEDROID_DB_PASSWD=
SCYTALEDROID_DB_SCHEME=mysql

# Optional single DSN (otherwise built from SCYTALEDROID_DB_* above).
# SCYTALEDROID_DB_URL=mysql://scytaledroid_operator:change-me@localhost:3306/scytaledroid_core_prod

SCYTALEDROID_API_KEY=change-me

# Legacy publication/export path toggle (default off).
SCYTALEDROID_ENABLE_LEGACY_PUBLICATION=0

# ---- Global runtime mode ----
# physical | virtual | validation — see run.sh / app_config
SCYTALEDROID_RUNTIME_PRESET=physical
SCYTALEDROID_DEBUG_MODE=False
SCYTALEDROID_EXECUTION_MODE=PROD
SCYTALEDROID_SYS_ENV=PHYSICAL
SCYTALEDROID_SYS_TEST=False

# ---- Static analysis paper grade ----
# 1 = canonical paper-grade path (Permission Intel + governance snapshots expected).
# 0 = experimental (no paper-grade gate messaging).
SCYTALEDROID_CANONICAL_GRADE=1

# Persist static findings to MariaDB when true (default on). Preflight prints skipped vs enabled.
# SCYTALEDROID_PERSISTENCE_READY=0

# Legacy mirror writers removed; static persistence uses static_analysis_* only.
# When unset, ``fetch_db_masvs_summary(None)`` will not read legacy ``runs``/``findings`` if no canonical run exists.
# SCYTALEDROID_ALLOW_LEGACY_MASVS_FALLBACK=1

# ---- Permission Intel (governance / reference tables; separate logical DB) ----
SCYTALEDROID_PERMISSION_INTEL_DB_HOST=localhost
SCYTALEDROID_PERMISSION_INTEL_DB_PORT=3306
SCYTALEDROID_PERMISSION_INTEL_DB_NAME=android_permission_intel
SCYTALEDROID_PERMISSION_INTEL_DB_USER=scytaledroid_operator
SCYTALEDROID_PERMISSION_INTEL_DB_PASSWD=

# Optional Intel DSN (overrides split vars when non-empty).
# SCYTALEDROID_PERMISSION_INTEL_DB_URL=mysql://user:pass@localhost:3306/android_permission_intel

# Static progress cadence (milestones every N artifacts)
SCYTALEDROID_STATIC_PROGRESS_EVERY=5

# APK harvest CLI (simple mode defaults): quieter progress milestones + omit long [COPY] from stdout (logs retain it).
# SCYTALEDROID_HARVEST_PROGRESS_EVERY=10
# SCYTALEDROID_HARVEST_COPY_LINE=1
# After canonical store materialization, replace session copies with symlinks (Unix; saves disk; default off).
# SCYTALEDROID_HARVEST_THIN_SESSION=1
