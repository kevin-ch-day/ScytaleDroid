# ScytaleDroid Environment (example)
#
# Copy to `.env` at repo root. Alternate path: set SCYTALEDROID_ENV_FILE (see `run_mariadb.sh`).
# To start the CLI with a MariaDB URL without importing Python first: `./run_mariadb.sh --help`

# ---- Database Credentials ----
SCYTALEDROID_DB_NAME=scytaledroid_core_prod
SCYTALEDROID_DB_USER=scytaledroid_operator
SCYTALEDROID_DB_PASSWD=change-me-now
SCYTALEDROID_DB_HOST=localhost
SCYTALEDROID_DB_PORT=3306
SCYTALEDROID_DB_SCHEME=mysql
SCYTALEDROID_API_KEY=change-me
# Legacy publication/export path toggle (default off).
SCYTALEDROID_ENABLE_LEGACY_PUBLICATION=0

# ---- Global Runtime Mode ----
# physical | virtual | validation — see run.sh / app_config
SCYTALEDROID_RUNTIME_PRESET=physical
SCYTALEDROID_DEBUG_MODE=False
SCYTALEDROID_EXECUTION_MODE=PROD
SCYTALEDROID_SYS_ENV=PHYSICAL
SCYTALEDROID_SYS_TEST=False

# Optional DSN override (otherwise built from SCYTALEDROID_DB_* above when the app loads).
# run_mariadb.sh can also build this URL from NAME/USER/PASSWD/HOST/PORT (stdlib helper).
# SCYTALEDROID_DB_URL=mysql://scytaledroid_operator:change-me-now@localhost:3306/scytaledroid_core_prod

# Static progress cadence (milestones every N artifacts)
SCYTALEDROID_STATIC_PROGRESS_EVERY=5

# APK harvest CLI (simple mode defaults): quieter progress milestones + omit long [COPY] from stdout (logs retain it).
# SCYTALEDROID_HARVEST_PROGRESS_EVERY=10
# SCYTALEDROID_HARVEST_COPY_LINE=1
# After canonical store materialization, replace session copies with symlinks (Unix; saves disk; default off).
# SCYTALEDROID_HARVEST_THIN_SESSION=1
