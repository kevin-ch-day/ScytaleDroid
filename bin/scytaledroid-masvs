#!/usr/bin/env python3
"""Summarise MASVS areas from ScytaleDroid baseline JSON."""

from __future__ import annotations

import argparse
import json
from pathlib import Path
from typing import Mapping, Sequence

_MASVS_AREAS = ("NETWORK", "PLATFORM", "PRIVACY", "STORAGE")
_FINDING_MAP = {
    "BASE-001": "PLATFORM",
    "BASE-002": "PLATFORM",
    "BASE-003": "PRIVACY",
    "BASE-004": "NETWORK",
    "BASE-005": "PRIVACY",
    "BASE-006": "STORAGE",
}


def _load_report(path: Path) -> Mapping[str, object]:
    with path.open("r", encoding="utf-8") as handle:
        payload = json.load(handle)
    if not isinstance(payload, Mapping):
        raise ValueError("report payload must be a JSON object")
    return payload


def _evaluate(payload: Mapping[str, object]) -> tuple[dict[str, str], dict[str, list[str]], float]:
    baseline = payload.get("baseline")
    findings = []
    if isinstance(baseline, Mapping):
        raw_findings = baseline.get("findings")
        if isinstance(raw_findings, Sequence):
            findings = [entry for entry in raw_findings if isinstance(entry, Mapping)]
    status: dict[str, str] = {area: "PASS" for area in _MASVS_AREAS}
    reasons: dict[str, list[str]] = {area: [] for area in _MASVS_AREAS}

    for finding in findings:
        finding_id = str(finding.get("id")) if finding.get("id") is not None else ""
        category = _FINDING_MAP.get(finding_id)
        if not category:
            continue
        status[category] = "FAIL"
        title = str(finding.get("title") or finding_id)
        reasons[category].append(f"{finding_id} {title}".strip())

    pass_count = sum(1 for area in _MASVS_AREAS if status[area] == "PASS")
    pass_pct = (pass_count / len(_MASVS_AREAS)) * 100 if _MASVS_AREAS else 0.0
    return status, reasons, pass_pct


def _render(path: Path, status: Mapping[str, str], reasons: Mapping[str, Sequence[str]], pass_pct: float) -> None:
    heading = f"MASVS Summary — {path.name}"
    print(heading)
    print("=" * min(len(heading), 60))
    for area in _MASVS_AREAS:
        area_status = status.get(area, "PASS")
        print(f"{area:<9}: {area_status}")
        for reason in reasons.get(area, ()):  # type: ignore[arg-type]
            print(f"  - {reason}")
    print(f"Pass%   : {pass_pct:.1f}")
    print()


def main() -> int:
    parser = argparse.ArgumentParser(description="Summarise MASVS areas from baseline JSON files.")
    parser.add_argument("reports", nargs="+", type=Path, help="Path(s) to baseline JSON files")
    args = parser.parse_args()

    exit_code = 0
    for report_path in args.reports:
        try:
            payload = _load_report(report_path)
            status, reasons, pass_pct = _evaluate(payload)
        except FileNotFoundError:
            print(f"Error: {report_path} not found")
            exit_code = 2
            continue
        except ValueError as exc:
            print(f"Error parsing {report_path}: {exc}")
            exit_code = 2
            continue
        except json.JSONDecodeError as exc:
            print(f"Error decoding JSON from {report_path}: {exc}")
            exit_code = 2
            continue

        _render(report_path, status, reasons, pass_pct)
        if any(status[area] == "FAIL" for area in _MASVS_AREAS):
            exit_code = max(exit_code, 1)

    return exit_code


if __name__ == "__main__":  # pragma: no cover - script entry point
    raise SystemExit(main())
